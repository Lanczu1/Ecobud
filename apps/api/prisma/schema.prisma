generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                           String                @id @default(cuid())
  name                         String
  email                        String                @unique
  passwordHash                 String                @map("password")
  role                         UserRole              @default(user)
  status                       UserStatus            @default(pending)
  points                       Int                   @default(0)
  currentStreak                Int                   @default(0) @map("streak_count")
  lastActionDate               DateTime?             @map("last_action_date")
  createdAt                    DateTime              @default(now()) @map("created_at")
  updatedAt                    DateTime              @updatedAt @map("updated_at")
  reviewedChallengeSubmissions ChallengeSubmission[] @relation("ModeratedChallengeSubmissions")
  challengeSubmissions         ChallengeSubmission[] @relation("SubmittedChallengeProofs")
  managedEvents                Event[]               @relation("ManagedEvents")
  eventRegistrations           EventRegistration[]
  habitCheckIns                HabitCheckIn[]
  profile                      Profile?
  updatedSettings              SystemSetting[]       @relation("SystemSettingUpdates")
  transparencyLogs             TransparencyLog[]
  badges                       UserBadge[]
  challengeProgress            UserChallenge[]
  auditLogs                    AuditLog[]
  lessonProgress               UserLessonProgress[]
  authoredLessons              Lesson[]              @relation("LessonAuthor")
  presenceSessions             PresenceSession[]
  stats                        UserStats?
  weeklyGoal                   UserWeeklyGoal?

  @@map("users")
}

model Profile {
  id              String  @id @default(cuid())
  userId          String  @unique
  displayName     String
  avatarUrl       String?
  headline        String?
  city            String?
  preferencesJson String?
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lesson {
  id               String               @id @default(cuid())
  title            String
  description      String
  content          String
  category         String
  imageUrl         String?
  durationMinutes  Int                  @default(8)
  rating           Float                @default(4.8)
  pointsReward     Int                  @default(10)
  featured         Boolean              @default(false)
  isPublished      Boolean              @default(false) @map("is_published")
  scheduledAt      DateTime?            @map("scheduled_at")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  createdById      String?              @map("created_by_id")
  quizPassingScore Int                  @default(70) @map("quiz_passing_score")
  transcript       String?
  videoUrl         String?
  difficulty       String               @default("Beginner")
  pages            LessonPage[]
  progress         UserLessonProgress[]
  createdBy        User?                @relation("LessonAuthor", fields: [createdById], references: [id])
  quizQuestions    QuizQuestion[]

  @@map("lessons")
}

model LessonPage {
  id          String   @id @default(cuid())
  lessonId    String   @map("lesson_id")
  title       String
  description String
  content     String
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("lesson_pages")
}

model QuizQuestion {
  id            String   @id @default(cuid())
  lessonId      String   @map("lesson_id")
  question      String
  optionA       String   @map("option_a")
  optionB       String   @map("option_b")
  optionC       String   @map("option_c")
  optionD       String   @map("option_d")
  correctAnswer String   @map("correct_answer")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  lesson        Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model UserLessonProgress {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  lessonId       String    @map("lesson_id")
  status         String    @default("not_started")
  progress       Int       @default(0)
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  videoTimestamp Float     @default(0) @map("video_timestamp")
  lesson         Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

model UserStats {
  userId          String   @id @map("user_id")
  currentStreak   Int      @default(0) @map("current_streak")
  ecoPoints       Int      @default(0) @map("eco_points")
  ecoCoins        Int      @default(0) @map("eco_coins")
  knowledgePoints Int      @default(0) @map("knowledge_points")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stats")
}

model UserWeeklyGoal {
  userId     String   @id @map("user_id")
  weeklyGoal Int      @default(5) @map("weekly_goal")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_weekly_goal")
}

model Challenge {
  id                  String                @id @default(cuid())
  title               String
  description         String
  difficulty          String
  category            String?
  durationDays        Int
  imageUrl            String?
  badgeLabel          String?
  active              Boolean               @default(true)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  ecoCoinReward       Int                   @default(0)
  expReward           Int                   @default(0)
  aiDetectionTargets  String[]
  aiMinimumConfidence Int?                  @default(80)
  type                String                @default("GENERAL")
  isFeatured          Boolean               @default(false)
  submissions         ChallengeSubmission[]
  userChallenges      UserChallenge[]
}

model UserChallenge {
  id                 String    @id @default(cuid())
  userId             String
  challengeId        String
  progressPercentage Int       @default(0)
  status             String    @default("IN_PROGRESS")
  startedAt          DateTime  @default(now())
  completedAt        DateTime?
  expirationDate     DateTime?
  challenge          Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
}

model ChallengeSubmission {
  id             String                    @id @default(cuid())
  userId         String
  challengeId    String
  proofText      String?
  proofUrl       String?
  afterProofUrl  String?
  status         ChallengeSubmissionStatus @default(pending)
  moderatorNotes String?
  flaggedReason  String?
  reviewedById   String?                   @map("reviewed_by_id")
  reviewedAt     DateTime?                 @map("reviewed_at")
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")
  challenge      Challenge                 @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  reviewer       User?                     @relation("ModeratedChallengeSubmissions", fields: [reviewedById], references: [id])
  user           User                      @relation("SubmittedChallengeProofs", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
}

model Habit {
  id           String         @id @default(cuid())
  slug         String         @unique
  title        String
  pointsReward Int
  active       Boolean        @default(true)
  checkIns     HabitCheckIn[]
}

model HabitCheckIn {
  id            String   @id @default(cuid())
  userId        String
  habitId       String
  dateKey       String
  pointsAwarded Int
  createdAt     DateTime @default(now())
  habit         Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, habitId, dateKey])
}

model Badge {
  id             String      @id @default(cuid())
  name           String      @unique
  description    String
  iconUrl        String
  requiredPoints Int
  accentColor    String?
  users          UserBadge[]
}

model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  badgeId    String
  unlockedAt DateTime @default(now())
  badge      Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model Event {
  id            String              @id @default(cuid())
  title         String
  description   String
  location      String
  date          DateTime
  capacity      Int
  pointsReward  Int
  managedById   String              @map("managed_by_id")
  imageUrl      String?
  latitude      Float?
  longitude     Float?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  managedBy     User                @relation("ManagedEvents", fields: [managedById], references: [id], onDelete: Cascade)
  registrations EventRegistration[]
}

model EventRegistration {
  id           String    @id @default(cuid())
  userId       String
  eventId      String
  status       String    @default("REGISTERED")
  registeredAt DateTime  @default(now())
  attendedAt   DateTime?
  event        Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model TransparencyLog {
  id            String   @id @default(cuid())
  userId        String
  actionType    String
  publicLabel   String
  pointsAwarded Int
  metadata      String?
  previousHash  String
  currentHash   String   @unique
  timestamp     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedBy   User?    @relation("SystemSettingUpdates", fields: [updatedById], references: [id])
}

model PresenceSession {
  sessionId       String                  @id @map("session_id")
  userId          String                  @map("user_id")
  isOnline        Boolean                 @default(true) @map("is_online")
  connectedAt     DateTime                @default(now()) @map("connected_at") @db.Timestamptz(3)
  lastSeenAt      DateTime                @default(now()) @map("last_seen_at") @db.Timestamptz(3)
  updatedAt       DateTime                @updatedAt @map("updated_at") @db.Timestamptz(3)
  disconnectedAt  DateTime?               @map("disconnected_at") @db.Timestamptz(3)
  expiresAt       DateTime                @map("expires_at") @db.Timestamptz(3)
  appState        PresenceAppState        @default(active) @map("app_state")
  connectionState PresenceConnectionState @default(online) @map("connection_state")
  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isOnline, expiresAt], map: "presence_sessions_online_expiry_idx")
  @@index([lastSeenAt], map: "presence_sessions_last_seen_idx")
  @@map("presence_sessions")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  userId    String?
  details   String?
  timestamp DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

enum UserRole {
  user
  moderator
  admin
}

enum UserStatus {
  active
  pending
  suspended
}

enum ChallengeSubmissionStatus {
  pending
  approved
  rejected
  flagged
}

enum PresenceAppState {
  active
  background
  inactive
}

enum PresenceConnectionState {
  online
  offline
  reconnecting
  stale
}
